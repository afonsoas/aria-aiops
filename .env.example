# ── ARIA AIOps — Variáveis de Ambiente ──────────────────────────
# Copie este arquivo para .env e preencha com suas credenciais OCI
# NUNCA commite o .env real no repositório

# ── Oracle Autonomous Database (OCI Always Free) ─────────────────
ARIA_DB_USER=ADMIN
ARIA_DB_PASSWORD=SuaSenhaAqui
ARIA_DB_DSN=seu_host_oci:1522/seu_service_name

# Wallet OCI (caminho para a pasta com os arquivos .ora / tnsnames.ora)
# Baixe em: OCI Console → Autonomous Database → Database Connection → Download Wallet
ARIA_WALLET_DIR=/app/wallet
ARIA_WALLET_PASSWORD=SenhaDaWallet

# ── Dashboard ────────────────────────────────────────────────────
# URL pública da API (usada pela Página 5 do dashboard)
# Exemplos:
#   Local:      http://localhost:8000
#   OCI:        http://IP_PUBLICO_OCI:8000
#   Render:     https://aria-aiops.onrender.com
ARIA_API_URL=http://localhost:8000

# ── Dataset ──────────────────────────────────────────────────────
# Deixe em branco para usar data/LW-DATASET.xlsx (padrão)
# ARIA_DATA_FILE=/caminho/alternativo/LW-DATASET.xlsx
