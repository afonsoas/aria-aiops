# ── ARIA AIOps — Streamlit Secrets ──────────────────────────────
# Para deploy no Streamlit Community Cloud:
#   1. Vá em App Settings → Secrets
#   2. Cole o conteúdo abaixo com seus valores reais
#
# Para desenvolvimento local:
#   Copie para .streamlit/secrets.toml (já está no .gitignore)

# URL pública da API FastAPI (OCI, Render, Railway etc.)
ARIA_API_URL = "http://localhost:8000"

# Oracle ADB — credenciais (usadas pela API, não pelo dashboard diretamente)
ARIA_DB_USER = "ADMIN"
ARIA_DB_PASSWORD = "SuaSenhaAqui"
ARIA_DB_DSN = "seu_host:1522/seu_service"
